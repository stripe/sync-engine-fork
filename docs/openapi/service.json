{
  "openapi": "3.0.0",
  "info": {
    "title": "Stripe Sync Service",
    "version": "1.0.0",
    "description": "Stripe Sync Service — manage pipelines and webhook ingress.\n\n## Endpoints\n\n| Method | Path | Summary |\n|--------|------|---------|\n| GET | /health | Health check |\n| GET | /pipelines | List pipelines |\n| POST | /pipelines | Create pipeline |\n| GET | /pipelines/{id} | Retrieve pipeline |\n| PATCH | /pipelines/{id} | Update pipeline |\n| DELETE | /pipelines/{id} | Delete pipeline |\n| POST | /webhooks/{pipeline_id} | Ingest a Stripe webhook event |"
  },
  "components": {
    "schemas": {},
    "parameters": {}
  },
  "paths": {
    "/health": {
      "get": {
        "operationId": "health",
        "tags": [
          "Status"
        ],
        "summary": "Health check",
        "responses": {
          "200": {
            "description": "Server is healthy",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean",
                      "enum": [
                        true
                      ]
                    }
                  },
                  "required": [
                    "ok"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "/pipelines": {
      "get": {
        "operationId": "listPipelines",
        "tags": [
          "Pipelines"
        ],
        "summary": "List pipelines",
        "responses": {
          "200": {
            "description": "List of pipelines",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "data": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "id": {
                            "type": "string"
                          },
                          "source": {
                            "type": "object",
                            "properties": {
                              "name": {
                                "type": "string"
                              }
                            },
                            "required": [
                              "name"
                            ],
                            "additionalProperties": {
                              "nullable": true
                            }
                          },
                          "destination": {
                            "type": "object",
                            "properties": {
                              "name": {
                                "type": "string"
                              }
                            },
                            "required": [
                              "name"
                            ],
                            "additionalProperties": {
                              "nullable": true
                            }
                          },
                          "streams": {
                            "type": "array",
                            "items": {
                              "type": "object",
                              "properties": {
                                "name": {
                                  "type": "string"
                                },
                                "sync_mode": {
                                  "type": "string",
                                  "enum": [
                                    "incremental",
                                    "full_refresh"
                                  ]
                                }
                              },
                              "required": [
                                "name"
                              ]
                            }
                          }
                        },
                        "required": [
                          "id",
                          "source",
                          "destination"
                        ]
                      }
                    },
                    "has_more": {
                      "type": "boolean"
                    }
                  },
                  "required": [
                    "data",
                    "has_more"
                  ]
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createPipeline",
        "tags": [
          "Pipelines"
        ],
        "summary": "Create pipeline",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "source": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "name"
                    ],
                    "additionalProperties": {
                      "nullable": true
                    }
                  },
                  "destination": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "name"
                    ],
                    "additionalProperties": {
                      "nullable": true
                    }
                  },
                  "streams": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "sync_mode": {
                          "type": "string",
                          "enum": [
                            "incremental",
                            "full_refresh"
                          ]
                        }
                      },
                      "required": [
                        "name"
                      ]
                    }
                  }
                },
                "required": [
                  "source",
                  "destination"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created pipeline",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "source": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "name"
                      ],
                      "additionalProperties": {
                        "nullable": true
                      }
                    },
                    "destination": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "name"
                      ],
                      "additionalProperties": {
                        "nullable": true
                      }
                    },
                    "streams": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string"
                          },
                          "sync_mode": {
                            "type": "string",
                            "enum": [
                              "incremental",
                              "full_refresh"
                            ]
                          }
                        },
                        "required": [
                          "name"
                        ]
                      }
                    }
                  },
                  "required": [
                    "id",
                    "source",
                    "destination"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Invalid input",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/pipelines/{id}": {
      "get": {
        "operationId": "getPipeline",
        "tags": [
          "Pipelines"
        ],
        "summary": "Retrieve pipeline",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "pipe_abc123"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Retrieved pipeline with status",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "source": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "name"
                      ],
                      "additionalProperties": {
                        "nullable": true
                      }
                    },
                    "destination": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        }
                      },
                      "required": [
                        "name"
                      ],
                      "additionalProperties": {
                        "nullable": true
                      }
                    },
                    "streams": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": {
                            "type": "string"
                          },
                          "sync_mode": {
                            "type": "string",
                            "enum": [
                              "incremental",
                              "full_refresh"
                            ]
                          }
                        },
                        "required": [
                          "name"
                        ]
                      }
                    },
                    "status": {
                      "type": "object",
                      "properties": {
                        "phase": {
                          "type": "string"
                        },
                        "paused": {
                          "type": "boolean"
                        },
                        "iteration": {
                          "type": "number"
                        }
                      },
                      "required": [
                        "phase",
                        "paused",
                        "iteration"
                      ]
                    }
                  },
                  "required": [
                    "id",
                    "source",
                    "destination"
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      },
      "patch": {
        "operationId": "updatePipeline",
        "tags": [
          "Pipelines"
        ],
        "summary": "Update pipeline",
        "description": "Update pipeline config. Include `{ \"paused\": true }` to pause or `{ \"paused\": false }` to resume.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "pipe_abc123"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "source": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "name"
                    ],
                    "additionalProperties": {
                      "nullable": true
                    }
                  },
                  "destination": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "name"
                    ],
                    "additionalProperties": {
                      "nullable": true
                    }
                  },
                  "streams": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "sync_mode": {
                          "type": "string",
                          "enum": [
                            "incremental",
                            "full_refresh"
                          ]
                        }
                      },
                      "required": [
                        "name"
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Update signal sent",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean",
                      "enum": [
                        true
                      ]
                    }
                  },
                  "required": [
                    "ok"
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deletePipeline",
        "tags": [
          "Pipelines"
        ],
        "summary": "Delete pipeline",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "pipe_abc123"
            },
            "required": true,
            "name": "id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Deleted pipeline",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "deleted": {
                      "type": "boolean",
                      "enum": [
                        true
                      ]
                    }
                  },
                  "required": [
                    "id",
                    "deleted"
                  ]
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": {
                      "nullable": true
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/webhooks/{pipeline_id}": {
      "post": {
        "operationId": "pushWebhook",
        "tags": [
          "Webhooks"
        ],
        "summary": "Ingest a Stripe webhook event",
        "description": "Receives a raw Stripe webhook event, verifies its signature using the pipeline's webhook secret, and enqueues it for processing by the active pipeline.",
        "parameters": [
          {
            "schema": {
              "type": "string",
              "example": "pipe_abc123"
            },
            "required": true,
            "name": "pipeline_id",
            "in": "path"
          }
        ],
        "responses": {
          "200": {
            "description": "Event accepted",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string",
                  "enum": [
                    "ok"
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}
